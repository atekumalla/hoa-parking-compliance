# Google Sheets Configuration
# Get Sheet ID from the URL: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Drive Configuration
# Create a folder in your personal Google Drive, then share it with the
# service account email (as Editor). Get Folder ID from the URL:
# https://drive.google.com/drive/folders/YOUR_FOLDER_ID
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Path to your Google Service Account JSON key file
# Download from Google Cloud Console > IAM & Admin > Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=service-account-key.json

# Scoreboard Configuration (optional, defaults to 20)
SCOREBOARD_TOP_N=20

# OpenAI API Key (optional - enables AI photo analysis for auto-filling vehicle details)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Vision Model (optional, defaults to gpt-4o-mini)
# Options: gpt-4o-mini (cheapest, recommended), gpt-4o, gpt-4.1-nano, gpt-4.1-mini, gpt-4.1
OPENAI_VISION_MODEL=gpt-4o-mini
